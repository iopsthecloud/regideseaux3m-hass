# Régie des Eaux Montpellier - Environment Variables
# Copy this file to .env and fill in your credentials

# Required for standalone testing
REGIE_USERNAME=your_email@example.com
REGIE_PASSWORD=your_password

# Optional: API endpoint overrides (for testing)
# REGIE_API_URL=https://ael.regiedeseaux3m.fr

# Optional: Logging level
# LOG_LEVEL=DEBUG

# Optional: Test configuration
# TEST_USERNAME=test@example.com
# TEST_PASSWORD=test_password
